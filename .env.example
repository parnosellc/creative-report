# Copy these into Railway → service → Variables (do NOT commit a real .env).

# Read-only system-user token (ads_read).
CPR_FB_TOKEN=PASTE_TOKEN_HERE

# Comma-separated ad account IDs WITHOUT the act_ prefix. Code prepends act_.
CPR_FB_AD_ACCOUNTS=445988994369431,2149427105556889

# Graph API version (bump here without a code change).
CPR_FB_API_VERSION=v21.0

# Secret URL segment for the live report. Make this long + random.
# Your live report will live at:  https://<your-app>.up.railway.app/<CPR_SECRET>/
CPR_SECRET=change-me-to-a-long-random-string

# Durable storage for saved snapshots. Point this at a mounted Railway Volume.
CPR_DATA_DIR=/data

# Do NOT set PORT — Railway injects it automatically.
